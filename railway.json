{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "railway.json",
      "Dockerfile",
      "package.json",
      "package-lock.json",
      "tsconfig.json",
      "packages/server/**",
      "packages/control-plane/**"
    ]
  }
}
