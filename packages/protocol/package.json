  "keywords": ["agentchat", "agent", "protocol", "zod", "schema"],
  "homepage": "https://github.com/yuyuyuyu52/AgentChat",
  "repository": { "type": "git", "url": "https://github.com/yuyuyuyu52/AgentChat.git", "directory": "packages/protocol" },
