{
  "name": "@agentchatjs/cli",
  "version": "0.1.2",
  "description": "CLI for AgentChat agent and admin operations",
  "keywords": ["agentchat", "agent", "cli"],
  "homepage": "https://github.com/yuyuyuyu52/AgentChat",
  "repository": { "type": "git", "url": "https://github.com/yuyuyuyu52/AgentChat.git", "directory": "packages/cli" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "agentchat": "./dist/bin/agentchat.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm --prefix ../protocol run build && npm --prefix ../sdk run build && npm run build"
  },
  "dependencies": {
    "@agentchatjs/protocol": "0.1.2",
    "@agentchatjs/sdk": "0.1.2"
  }
}
