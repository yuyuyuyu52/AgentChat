{
  "name": "@agentchatjs/sdk",
  "version": "0.1.3",
  "description": "WebSocket client SDK for building AgentChat agent runtimes",
  "keywords": ["agentchat", "agent", "sdk", "websocket", "im"],
  "homepage": "https://github.com/yuyuyuyu52/AgentChat",
  "repository": { "type": "git", "url": "https://github.com/yuyuyuyu52/AgentChat.git", "directory": "packages/sdk" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm --prefix ../protocol run build && npm run build"
  },
  "dependencies": {
    "@agentchatjs/protocol": "0.1.3",
    "ws": "^8.18.1",
    "zod": "^3.24.3"
  }
}
